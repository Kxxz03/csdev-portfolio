---
import '../styles/barro.css';

interface Props {
  title?: string;
  activePage?: 'home' | 'catalogo' | 'nosotros';
}
const { title = 'BARRO MX Store', activePage } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — BARRO MX</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Scan lines -->
  <div class="scan-lines"></div>

  <!-- Cursor crosshair -->
  <div class="cursor-cross" id="b-cur" style="opacity:0">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <circle cx="14" cy="14" r="11" stroke="#FF4D00" stroke-width="1"/>
      <line x1="14" y1="2"  x2="14" y2="8"  stroke="#FF4D00" stroke-width="1"/>
      <line x1="14" y1="20" x2="14" y2="26" stroke="#FF4D00" stroke-width="1"/>
      <line x1="2"  y1="14" x2="8"  y2="14" stroke="#FF4D00" stroke-width="1"/>
      <line x1="20" y1="14" x2="26" y2="14" stroke="#FF4D00" stroke-width="1"/>
    </svg>
  </div>
  <div class="cursor-dot" id="b-dot" style="width:4px;height:4px;background:#FF4D00;border-radius:50%;opacity:0"></div>

  <!-- Speed lines on load -->
  <div class="speed-line" id="speed-lines"></div>

  <!-- NAV -->
  <header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur">
    <div class="mx-auto flex h-16 max-w-[1600px] items-center justify-between px-6">
      <a href="/barro" class="flex items-baseline gap-2">
        <span class="font-display text-3xl tracking-tight">BAR<span class="text-primary">RO</span></span>
        <span class="hidden font-condensed text-[10px] uppercase tracking-[0.3em] text-muted-foreground sm:inline">/// MX Equip</span>
      </a>
      <nav class="hidden items-center gap-1 md:flex">
        <a href="/barro"
           class={`font-condensed text-lg uppercase tracking-widest px-4 py-2 transition-colors ${activePage === 'home' ? 'text-primary' : 'text-foreground hover:text-primary'}`}>
          Base
        </a>
        <a href="/barro/catalogo"
           class={`font-condensed text-lg uppercase tracking-widest px-4 py-2 transition-colors ${activePage === 'catalogo' ? 'text-primary' : 'text-foreground hover:text-primary'}`}>
          Catálogo
        </a>
        <a href="/barro/nosotros"
           class={`font-condensed text-lg uppercase tracking-widest px-4 py-2 transition-colors ${activePage === 'nosotros' ? 'text-primary' : 'text-foreground hover:text-primary'}`}>
          Nosotros
        </a>
      </nav>
      <div class="flex items-center gap-3">
        <button id="cart-btn"
          class="group relative flex items-center gap-2 border border-primary bg-background px-4 py-2 font-condensed text-sm uppercase tracking-widest text-foreground transition-all hover:bg-primary hover:text-background">
          <span>Cart</span>
          <span id="cart-count"
            class="flex h-5 min-w-5 items-center justify-center bg-primary px-1 font-mono text-xs text-background group-hover:bg-background group-hover:text-primary">
            0
          </span>
        </button>
        <a href="/"
           class="font-condensed text-[10px] uppercase tracking-[0.18em] text-foreground/20 border-l border-border pl-3 hover:text-primary transition-colors">
          ← +CSDEV
        </a>
      </div>
    </div>
  </header>

  <!-- PAGE CONTENT -->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="border-t border-border bg-background">
    <div class="mx-auto flex max-w-[1600px] flex-col gap-6 px-6 py-10 md:flex-row md:items-center md:justify-between">
      <a href="/barro" class="font-display text-2xl">BAR<span class="text-primary">RO</span> <span class="text-muted-foreground text-lg">MX</span></a>
      <nav class="flex flex-wrap gap-6">
        <a href="/barro"          class="font-condensed text-xs uppercase tracking-widest text-muted-foreground hover:text-primary transition-colors">Base</a>
        <a href="/barro/catalogo" class="font-condensed text-xs uppercase tracking-widest text-muted-foreground hover:text-primary transition-colors">Catálogo</a>
        <a href="/barro/nosotros" class="font-condensed text-xs uppercase tracking-widest text-muted-foreground hover:text-primary transition-colors">Nosotros</a>
        <a href="#"               class="font-condensed text-xs uppercase tracking-widest text-muted-foreground hover:text-primary transition-colors">Contacto</a>
      </nav>
      <div class="flex flex-col gap-1 text-right">
        <span class="font-mono text-[10px] uppercase tracking-widest text-muted-foreground">© 2026 BARRO MX — PARAGUAY</span>
        <a href="/" class="font-condensed text-[10px] uppercase tracking-widest text-muted-foreground hover:text-primary transition-colors">DISEÑO POR +CSDEV</a>
      </div>
    </div>
  </footer>

  <script>
    // Cursor
    const cur = document.getElementById('b-cur') as HTMLElement | null;
    const dot = document.getElementById('b-dot') as HTMLElement | null;
    let mx = 0, my = 0, cx = 0, cy = 0;
    let cursorReady = false;
    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      if (!cursorReady) {
        cursorReady = true;
        if (cur) cur.style.opacity = '1';
        if (dot) dot.style.opacity = '1';
      }
    });
    (function animCursor() {
      cx += (mx - cx) * 0.12; cy += (my - cy) * 0.12;
      if (cur) cur.style.transform = `translate(calc(${cx}px - 50%), calc(${cy}px - 50%))`;
      if (dot) dot.style.transform = `translate(calc(${mx}px - 50%), calc(${my}px - 50%))`;
      requestAnimationFrame(animCursor);
    })();
    document.querySelectorAll('a,button,[data-cursor]').forEach(el => {
      el.addEventListener('mouseenter', () => { if(cur){ cur.style.width='40px'; cur.style.height='40px'; } });
      el.addEventListener('mouseleave', () => { if(cur){ cur.style.width='28px'; cur.style.height='28px'; } });
    });

    // Speed lines
    const sl = document.getElementById('speed-lines');
    if (sl) {
      for (let i = 0; i < 18; i++) {
        const s = document.createElement('span');
        s.style.top = `${Math.random()*100}%`;
        s.style.width = `${80+Math.random()*200}px`;
        s.style.animationDelay = `${Math.random()*0.3}s`;
        s.style.opacity = `${0.3+Math.random()*0.7}`;
        sl.appendChild(s);
      }
      setTimeout(() => sl.remove(), 1200);
    }

    // Scroll reveal
    document.querySelectorAll('[data-reveal]').forEach(el => {
      new IntersectionObserver(([e]) => {
        if (e.isIntersecting) { e.target.classList.add('revealed'); }
      }, { threshold: 0.15 }).observe(el);
    });
  </script>
</body>
</html>
