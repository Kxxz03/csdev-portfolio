<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Hero entrance
  gsap.fromTo('#heroHeadline',
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 1, ease: 'power3.out', delay: 0.1 }
  );
  gsap.fromTo('#heroSub',
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out', delay: 0.35 }
  );

  // Scroll reveals
  document.querySelectorAll('[data-reveal]').forEach((el) => {
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.75,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 88%',
        once: true,
      },
    });
  });

  // Encargos form → WhatsApp
  const WHATSAPP = '595982441207';
  document.getElementById('encargosForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const f = new FormData(e.currentTarget as HTMLFormElement);
    const msg = encodeURIComponent(
      `Hola MIEL! Soy ${f.get('nombre')}.\nFecha: ${f.get('fecha')}\nPedido: ${f.get('pedido')}`
    );
    window.open(`https://wa.me/${WHATSAPP}?text=${msg}`, '_blank');
  });
</script>
