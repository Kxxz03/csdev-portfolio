<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Nav scroll state
  const nav = document.getElementById('nav')!;
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  // Programs full-row reveal (GSAP-driven)
  const rows = document.querySelectorAll<HTMLElement>('.program-row');
  const COLLAPSED = 88;
  const EXPANDED = 280;

  rows.forEach(row => {
    const content = row.querySelector<HTMLElement>('.program-content')!;
    const bg = row.querySelector<HTMLElement>('.program-bg')!;
    const desc = row.querySelector<HTMLElement>('.program-desc')!;
    const num = row.querySelector<HTMLElement>('.program-num')!;
    const arrow = row.querySelector<HTMLElement>('.program-arrow')!;
    const cat = row.querySelector<HTMLElement>('.program-cat')!;

    // overflow already set in CSS; GSAP animates height

    row.addEventListener('mouseenter', () => {
      gsap.to(row, { height: EXPANDED, duration: 0.55, ease: 'power3.out' });
      gsap.to(bg, { opacity: 1, scale: 1, duration: 0.55, ease: 'power3.out' });
      gsap.to(desc, { opacity: 1, y: 0, duration: 0.35, ease: 'power2.out', delay: 0.15 });
      gsap.to(arrow, { opacity: 1, x: 2, y: -2, duration: 0.25, ease: 'power2.out' });
      gsap.to(cat, { color: '#E85D04', duration: 0.2 });
      gsap.to(num, { opacity: 1, duration: 0.2 });
    });

    row.addEventListener('mouseleave', () => {
      gsap.to(row, { height: COLLAPSED, duration: 0.4, ease: 'power3.inOut' });
      gsap.to(bg, { opacity: 0, scale: 1.06, duration: 0.4, ease: 'power3.inOut' });
      gsap.to(desc, { opacity: 0, y: 6, duration: 0.2, ease: 'power2.in' });
      gsap.to(arrow, { opacity: 0, x: -6, y: 4, duration: 0.2 });
      gsap.to(cat, { color: 'rgba(255,255,255,0.35)', duration: 0.2 });
      gsap.to(num, { opacity: 0.4, duration: 0.2 });
    });
  });

  // Hero entrance
  const tl = gsap.timeline({ delay: 0.2 });
  tl.to('#heroEyebrow', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' })
    .to('#heroHeadline', { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out' }, '-=0.4')
    .to('#heroSub',     { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.5');

  // Scroll reveals
  document.querySelectorAll('[data-reveal]').forEach((el) => {
    const delay = parseFloat((el as HTMLElement).dataset.revealDelay || '0') * 0.15;
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      delay,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 88%',
        once: true,
      },
    });
  });
</script>
